#!/bin/bash

# Author: Bruno Pavelja - Bruno_AFK - Paveljame IT
# Web: pavelja.me
# Version: 1.1
# Description: Docker security scanner using Trivy. Scans running container images for vulnerabilities.

# Default Trivy image pinned by digest — DO NOT use :latest.
# Trivy had a supply chain compromise (v0.69.4-0.69.6).
# Override via TRIVY_IMAGE in ~/.config/llama_env/.env
TRIVY_IMAGE_DEFAULT="aquasec/trivy@sha256:bcc376de8d77cfe086a917230e818dc9f8528e3c852f7b1aff648949b6258d1c"

# Severity levels to report (comma-separated)
SEVERITY="CRITICAL,HIGH,MEDIUM,LOW"

# Cache directory for Trivy DB (persisted between runs)
TRIVY_CACHE_DIR="$HOME/.cache/trivy"

#------------------------------------------------------------------------------
# Colors
#------------------------------------------------------------------------------
RED='\e[1;31m'
GREEN='\e[1;32m'
YELLOW='\e[1;33m'
BLUE='\e[1;34m'
CYAN='\e[1;36m'
NC='\e[0m'

#------------------------------------------------------------------------------
# Notification support (reuses docker-update .env)
#------------------------------------------------------------------------------
ENV_FILE="$HOME/.config/llama_env/.env"

load_env_file() {
    [ ! -f "$ENV_FILE" ] && return 0
    while IFS= read -r line || [ -n "$line" ]; do
        case "$line" in
            ""|\#*) continue ;;
        esac
        if [[ "$line" =~ ^[A-Za-z_][A-Za-z0-9_]*= ]]; then
            local key="${line%%=*}"
            local value="${line#*=}"
            if [[ "$key" != NOTIFY_* && "$key" != "TRIVY_IMAGE" ]]; then
                continue
            fi
            if [[ "$value" =~ ^\".*\"$ ]]; then
                value="${value:1:-1}"
            elif [[ "$value" =~ ^\'.*\'$ ]]; then
                value="${value:1:-1}"
            fi
            export "$key=$value"
        fi
    done < "$ENV_FILE"
}

notify_telegram() {
    local msg="$1"
    local token="${NOTIFY_TELEGRAM_BOT_TOKEN:-}"
    local chat="${NOTIFY_TELEGRAM_CHAT_ID:-}"
    [ -z "$token" ] || [ -z "$chat" ] && return 0
    curl -fsSL -X POST "https://api.telegram.org/bot${token}/sendMessage" \
        -d chat_id="$chat" -d text="$msg" -d parse_mode="Markdown" >/dev/null 2>&1 || true
}

notify_slack() {
    local msg="$1"
    local url="${NOTIFY_SLACK_WEBHOOK_URL:-}"
    [ -z "$url" ] && return 0
    curl -fsSL -X POST "$url" -H 'Content-Type: application/json' \
        -d "{\"text\": \"$msg\"}" >/dev/null 2>&1 || true
}

notify_discord() {
    local msg="$1"
    local url="${NOTIFY_DISCORD_WEBHOOK_URL:-}"
    [ -z "$url" ] && return 0
    curl -fsSL -X POST "$url" -H 'Content-Type: application/json' \
        -d "{\"content\": \"$msg\"}" >/dev/null 2>&1 || true
}

notify_webhook() {
    local msg="$1"
    local url="${NOTIFY_WEBHOOK_URL:-}"
    [ -z "$url" ] && return 0
    local hostname
    hostname=$(hostname 2>/dev/null || echo "unknown")
    curl -fsSL -X POST "$url" -H 'Content-Type: application/json' \
        -d "{\"host\": \"$hostname\", \"event\": \"docker-scan\", \"message\": \"$msg\", \"timestamp\": \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"}" \
        >/dev/null 2>&1 || true
}

send_notifications() {
    local msg="$1"
    [ -z "$msg" ] && return 0
    notify_telegram "$msg"
    notify_slack "$msg"
    notify_discord "$msg"
    notify_webhook "$msg"
}

#------------------------------------------------------------------------------
# Trivy runner
#------------------------------------------------------------------------------

# Resolve TRIVY_IMAGE: .env override > default
resolve_trivy_image() {
    TRIVY_IMAGE="${TRIVY_IMAGE:-$TRIVY_IMAGE_DEFAULT}"
}

run_trivy() {
    docker run --rm \
        -v /var/run/docker.sock:/var/run/docker.sock \
        -v "$TRIVY_CACHE_DIR:/root/.cache/" \
        "$TRIVY_IMAGE" \
        "$@"
}

# Parse trivy JSON output and extract counts per severity
parse_severity_counts() {
    local json_file="$1"
    local critical=0 high=0 medium=0 low=0

    if command -v jq >/dev/null 2>&1; then
        critical=$(jq '[.Results[]?.Vulnerabilities[]? | select(.Severity=="CRITICAL")] | length' "$json_file" 2>/dev/null || echo 0)
        high=$(jq '[.Results[]?.Vulnerabilities[]? | select(.Severity=="HIGH")] | length' "$json_file" 2>/dev/null || echo 0)
        medium=$(jq '[.Results[]?.Vulnerabilities[]? | select(.Severity=="MEDIUM")] | length' "$json_file" 2>/dev/null || echo 0)
        low=$(jq '[.Results[]?.Vulnerabilities[]? | select(.Severity=="LOW")] | length' "$json_file" 2>/dev/null || echo 0)
    else
        critical=$(grep -c '"CRITICAL"' "$json_file" 2>/dev/null || true)
        high=$(grep -c '"HIGH"' "$json_file" 2>/dev/null || true)
        medium=$(grep -c '"MEDIUM"' "$json_file" 2>/dev/null || true)
        low=$(grep -c '"LOW"' "$json_file" 2>/dev/null || true)
    fi

    # Ensure numeric values (default to 0 if empty)
    echo "${critical:-0} ${high:-0} ${medium:-0} ${low:-0}"
}

# Extract top CVE details from JSON for verbose output
show_cve_details() {
    local json_file="$1"
    local severity_filter="$2"
    local max_items="${3:-10}"

    if command -v jq >/dev/null 2>&1; then
        local query
        if [ -n "$severity_filter" ]; then
            query="[.Results[]?.Vulnerabilities[]? | select(.Severity==\"$severity_filter\")] | sort_by(.CVSS // {} | to_entries | map(.value.V3Score // 0) | max // 0) | reverse | .[:${max_items}][] | \"\(.VulnerabilityID) \(.Severity) \(.PkgName) \(.InstalledVersion) \(.Title // \"No description\")\""
        else
            query="[.Results[]?.Vulnerabilities[]?] | sort_by(if .Severity == \"CRITICAL\" then 0 elif .Severity == \"HIGH\" then 1 elif .Severity == \"MEDIUM\" then 2 else 3 end) | .[:${max_items}][] | \"\(.VulnerabilityID) \(.Severity) \(.PkgName) \(.InstalledVersion) \(.Title // \"No description\")\""
        fi

        local output
        output=$(jq -r "$query" "$json_file" 2>/dev/null) || return 0

        [ -z "$output" ] && return 0

        while IFS= read -r line; do
            local cve sev pkg ver desc
            cve=$(echo "$line" | awk '{print $1}')
            sev=$(echo "$line" | awk '{print $2}')
            pkg=$(echo "$line" | awk '{print $3}')
            ver=$(echo "$line" | awk '{print $4}')
            desc=$(echo "$line" | cut -d' ' -f5-)

            # Truncate description
            [ ${#desc} -gt 60 ] && desc="${desc:0:57}..."

            local sev_color="$NC"
            case "$sev" in
                CRITICAL) sev_color="$RED" ;;
                HIGH) sev_color="$YELLOW" ;;
            esac

            printf "      ${sev_color}%-16s${NC} %-12s %-20s %s\n" "$cve" "$sev" "$pkg ($ver)" "$desc"
        done <<< "$output"
    else
        echo "      (install jq for detailed CVE output)"
    fi
}

# Format severity counts with colors
format_counts() {
    local critical="${1:-0}" high="${2:-0}" medium="${3:-0}" low="${4:-0}"
    local parts=""

    if [ "$critical" -gt 0 ] 2>/dev/null; then
        parts="${RED}CRITICAL: $critical${NC}"
    else
        parts="CRITICAL: 0"
    fi

    if [ "$high" -gt 0 ] 2>/dev/null; then
        parts="$parts  ${YELLOW}HIGH: $high${NC}"
    else
        parts="$parts  HIGH: 0"
    fi

    parts="$parts  MEDIUM: ${medium:-0}  LOW: ${low:-0}"
    echo -e "    $parts"
}

#------------------------------------------------------------------------------
# Scan commands
#------------------------------------------------------------------------------

scan_containers() {
    local severity_filter="${1:-$SEVERITY}"
    local verbose="$2"
    local tmpdir
    tmpdir=$(mktemp -d)
    trap "rm -rf '$tmpdir'" EXIT

    mkdir -p "$TRIVY_CACHE_DIR"

    echo -e "${BLUE}Updating Trivy vulnerability database...${NC}"
    run_trivy image --download-db-only -q 2>/dev/null || true
    echo

    echo -e "${BLUE}Scanning running containers...${NC}"
    echo

    local containers
    containers=$(docker ps --format '{{.Names}}' 2>/dev/null)

    if [ -z "$containers" ]; then
        echo -e "${YELLOW}No running containers found.${NC}"
        return 0
    fi

    local checked=0
    local total_critical=0
    local total_high=0
    local results=()
    local critical_containers=()

    while IFS= read -r container; do
        local image
        image=$(docker inspect --format '{{.Config.Image}}' "$container" 2>/dev/null)
        checked=$((checked + 1))

        echo -e "${CYAN}[$checked]${NC} Scanning ${CYAN}$container${NC} ($image)..."

        local json_out="$tmpdir/${container}.json"

        if run_trivy image --severity "$severity_filter" --format json \
            --quiet "$image" > "$json_out" 2>/dev/null; then

            local counts
            counts=$(parse_severity_counts "$json_out")
            local critical high medium low
            read -r critical high medium low <<< "$counts"

            format_counts "$critical" "$high" "$medium" "$low"

            # Show CVE details in verbose mode
            if [ "$verbose" = "true" ] && [ "${critical:-0}" -gt 0 -o "${high:-0}" -gt 0 ] 2>/dev/null; then
                echo
                show_cve_details "$json_out" "" 10
            fi

            total_critical=$((total_critical + ${critical:-0}))
            total_high=$((total_high + ${high:-0}))
            results+=("$container|$image|$critical|$high|$medium|$low")

            if [ "${critical:-0}" -gt 0 ] 2>/dev/null; then
                critical_containers+=("$container ($image): $critical critical")
            fi
        else
            echo -e "    ${RED}Scan failed${NC}"
            results+=("$container|$image|FAIL")
        fi

        echo
    done <<< "$containers"

    # Summary
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BLUE}Scan Summary${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "  Containers scanned: $checked"
    echo -e "  Total CRITICAL:     ${RED}$total_critical${NC}"
    echo -e "  Total HIGH:         ${YELLOW}$total_high${NC}"

    if [ ${#critical_containers[@]} -gt 0 ]; then
        echo
        echo -e "  ${RED}Containers with CRITICAL vulnerabilities:${NC}"
        for c in "${critical_containers[@]}"; do
            echo "    - $c"
        done
    fi

    if [ $total_critical -eq 0 ] && [ $total_high -eq 0 ]; then
        echo
        echo -e "  ${GREEN}No critical or high vulnerabilities found.${NC}"
    fi

    # Send notification if there are critical findings
    if [ $total_critical -gt 0 ]; then
        local hostname
        hostname=$(hostname 2>/dev/null || echo "unknown")
        local notify_msg="*Docker Scan Report* ($hostname)
Scanned: $checked containers
CRITICAL: $total_critical | HIGH: $total_high

Containers with CRITICAL issues:
$(printf '%s\n' "${critical_containers[@]}")"
        send_notifications "$notify_msg"
    fi

    echo
    [ $total_critical -gt 0 ] && return 1
    return 0
}

scan_image() {
    local image="$1"
    if [ -z "$image" ]; then
        echo -e "${RED}Error:${NC} Specify an image to scan."
        echo "Usage: llama docker-scan image <image-name>"
        exit 1
    fi

    mkdir -p "$TRIVY_CACHE_DIR"

    echo -e "${BLUE}Scanning image: ${CYAN}$image${NC}"
    echo
    run_trivy image --severity "$SEVERITY" "$image"
}

check_trivy_update() {
    echo -e "${BLUE}Current Trivy image:${NC}"
    echo "  $TRIVY_IMAGE"
    if [ -n "${TRIVY_IMAGE_FROM_ENV:-}" ]; then
        echo "  (from .env override)"
    else
        echo "  (default — no override in .env)"
    fi
    echo

    echo -e "${BLUE}Checking for latest version...${NC}"
    local latest_tag
    latest_tag=$(curl -fsSL "https://api.github.com/repos/aquasecurity/trivy/releases/latest" 2>/dev/null \
        | grep '"tag_name"' | head -1 | sed -E 's/.*"tag_name"[[:space:]]*:[[:space:]]*"v?([^"]+)".*/\1/')

    if [ -z "$latest_tag" ]; then
        echo -e "${RED}Could not fetch latest version.${NC}"
        return 1
    fi

    echo "  Latest release: $latest_tag"
    echo

    echo "To update:"
    echo "  1. Check release notes for security issues:"
    echo "     https://github.com/aquasecurity/trivy/releases/tag/v$latest_tag"
    echo
    echo "  2. Pull the new version and get its digest:"
    echo "     docker pull aquasec/trivy:$latest_tag"
    echo "     docker inspect --format '{{index .RepoDigests 0}}' aquasec/trivy:$latest_tag"
    echo
    echo "  3. Add to $ENV_FILE:"
    echo "     TRIVY_IMAGE=aquasec/trivy@sha256:<digest-from-step-2>"
}

#------------------------------------------------------------------------------
# Help
#------------------------------------------------------------------------------
show_help() {
    echo -e "${BLUE}Docker Security Scanner v1.1${NC}"
    echo
    echo -e "${GREEN}Description:${NC}"
    echo "  Scans Docker container images for vulnerabilities using Trivy."
    echo "  Trivy runs as a pinned Docker container — no host install needed."
    echo
    echo -e "${YELLOW}Usage:${NC}"
    echo "  llama docker-scan <command> [flags]"
    echo
    echo -e "${YELLOW}Commands:${NC}"
    printf "%-30s %-50s\n" "run" "Scan all running containers (summary)"
    printf "%-30s %-50s\n" "run --verbose" "Scan with CVE details per container"
    printf "%-30s %-50s\n" "run --critical" "Only CRITICAL vulnerabilities"
    printf "%-30s %-50s\n" "run --critical --verbose" "CRITICAL with details"
    printf "%-30s %-50s\n" "image <name>" "Full Trivy output for one image"
    printf "%-30s %-50s\n" "check-trivy" "Check for Trivy updates"
    printf "%-30s %-50s\n" "help, -h" "Show this help"
    echo
    echo -e "${YELLOW}Examples:${NC}"
    echo "  llama docker-scan run"
    echo "  llama docker-scan run --verbose"
    echo "  llama docker-scan run --critical --verbose"
    echo "  llama docker-scan image nginx:1.27"
    echo "  llama docker-scan check-trivy"
    echo
    echo -e "${YELLOW}Trivy:${NC}"
    echo "  Image: $TRIVY_IMAGE"
    echo "  Pinned by sha256 digest (not :latest) due to a past supply"
    echo "  chain compromise (v0.69.4-0.69.6)."
    echo "  Override via TRIVY_IMAGE in $ENV_FILE"
    echo "  Run 'check-trivy' for update instructions."
    echo
    echo -e "${YELLOW}Notifications:${NC}"
    echo "  Reuses the same .env config as docker-update ($ENV_FILE)."
    echo "  Notifications are sent only when CRITICAL vulnerabilities are found."
}

#------------------------------------------------------------------------------
# Main
#------------------------------------------------------------------------------
if [[ "$1" == "-h" || "$1" == "help" ]]; then
    show_help
    exit 0
fi

if ! command -v docker >/dev/null 2>&1; then
    echo -e "${RED}Error:${NC} Docker is not installed."
    exit 1
fi

if ! docker info >/dev/null 2>&1; then
    echo -e "${RED}Error:${NC} Docker is not running."
    exit 1
fi

load_env_file
# Track if TRIVY_IMAGE was set by .env before resolving default
[ -n "${TRIVY_IMAGE:-}" ] && TRIVY_IMAGE_FROM_ENV=1
resolve_trivy_image

case "$1" in
    "run")
        severity="$SEVERITY"
        verbose="false"
        shift
        while [ $# -gt 0 ]; do
            case "$1" in
                --critical) severity="CRITICAL" ;;
                --verbose|-v) verbose="true" ;;
                *) echo -e "${RED}Unknown flag:${NC} $1"; exit 1 ;;
            esac
            shift
        done
        scan_containers "$severity" "$verbose"
        ;;
    "image")
        scan_image "$2"
        ;;
    "check-trivy")
        check_trivy_update
        ;;
    *)
        echo -e "${RED}Error:${NC} Unknown command '$1'. Use 'help' for usage."
        exit 1
        ;;
esac
