#!/bin/bash

# Information header
# Author: Bruno Pavelja - Bruno_AFK - Paveljame IT      
# Web: pavelja.me
# Github: github.com/brunoafk
# Version: 1.0
# Description: A test script

#------------------------------------------------------------------------------
# Colors
#------------------------------------------------------------------------------
RED=$'\033[1;31m'
GREEN=$'\033[1;32m'
YELLOW=$'\033[1;33m'
BLUE=$'\033[1;34m'
CYAN=$'\033[1;36m'
MAGENTA=$'\033[1;35m'
GRAY=$'\033[1;90m'
WHITE=$'\033[0;37m'
NC=$'\033[0m'

# Function to display help information
show_help() {
    echo "${BLUE}Test Script v1.0${NC}"
    echo
    echo "${GREEN}Description:${NC}"
    echo "  This script demonstrates various bash script functionalities and argument handling."
    echo
    echo "${YELLOW}Usage:${NC}"
    echo "  ./test.sh [COMMAND] [ARGS]"
    echo
    echo "${YELLOW}Commands:${NC}"
    printf "%-15s %-50s\n" "help, -h" "Show this help message"
    printf "%-15s %-50s\n" "echo [TEXT]" "Echo back the provided text"
    printf "%-15s %-50s\n" "list" "List files in current directory"
    printf "%-15s %-50s\n" "date" "Show current date and time"
}

# Check if help is requested
if [[ "$1" == "-h" || "$1" == "help" ]]; then
    show_help
    exit 0
fi

# Handle different commands
case "$1" in
    "echo")
        shift  # Remove first argument
        echo "${CYAN}📢 Echo Output:${NC}"
        echo "${YELLOW}$@${NC}"
        ;;
    "list")
        echo "${CYAN}📂 Directory Contents:${NC}"
        echo "${YELLOW}Location: $(pwd)${NC}"
        echo "${YELLOW}Total items: $(ls -1 | wc -l)${NC}"
        echo "----------------------------------------"
        # Enhanced ls with colors and formatting
        ls -la | awk -v blue=$'\033[1;34m' -v cyan=$'\033[1;36m' -v green=$'\033[1;32m' -v white=$'\033[0;37m' -v nc=$'\033[0m' '
            NR==1 {print blue $0 nc; next}
            {
                if($1 ~ /^d/) printf "%s%s%s\n", cyan, $0, nc;
                else if($1 ~ /^-.*x/) printf "%s%s%s\n", green, $0, nc;
                else printf "%s%s%s\n", white, $0, nc;
            }'
        echo "----------------------------------------"
        echo "${GRAY}ℹ️  Colors: ${CYAN}Directories${NC}, ${GREEN}Executables${NC}, ${WHITE}Files${NC}"
        ;;
    "date")
        echo "${CYAN}🕒 Time Information:${NC}"
        echo "${YELLOW}Current Time: ${NC}$(date +"%I:%M:%S %p")"
        echo "${YELLOW}Date: ${NC}$(date +"%A, %B %d, %Y")"
        echo "${YELLOW}Timezone: ${NC}$(date +"%Z")"
        echo "${YELLOW}Unix Timestamp: ${NC}$(date +%s)"
        echo "${YELLOW}Week Number: ${NC}$(date +%V)"
        echo
        # ASCII art clock (basic)
        hour=$(date +%I)
        echo "${MAGENTA}   ┌─────────┐"
        echo "   │  ${hour}:$(date +%M)  │"
        echo "   └─────────┘${NC}"
        ;;
    *)
        echo "${RED}❌ Error:${NC} Invalid command. Use 'help' for usage information."
        exit 1
        ;;
esac
