#!/bin/bash

# Author: Bruno Pavelja - Bruno_AFK - Paveljame IT
# Web: pavelja.me
# Github: github.com/brunoafk
# Version: 1.0
# Description: Switch Codex CLI and app profiles by managing separate CODEX_HOME snapshots.

VERSION="1.0"

RED=$'\033[1;31m'
GREEN=$'\033[1;32m'
YELLOW=$'\033[1;33m'
BLUE=$'\033[1;34m'
CYAN=$'\033[1;36m'
GRAY=$'\033[90m'
NC=$'\033[0m'

CONFIG_DIR="${LLAMA_CODEX_SWITCH_DIR:-$HOME/.config/llama_env/codex-switch}"
PROFILES_DIR="$CONFIG_DIR/profiles"
BACKUPS_DIR="$CONFIG_DIR/backups"
ACTIVE_APP_PROFILE_FILE="$CONFIG_DIR/active-app-profile"
ACTIVE_APP_HOME_FILE="$CONFIG_DIR/active-app-home"

show_help() {
    echo "${BLUE}Codex Profile Switcher v$VERSION${NC}"
    echo
    echo "${GREEN}Usage:${NC}"
    echo "  llama codex-switch <command> [args]"
    echo
    echo "${YELLOW}Commands:${NC}"
    printf "%-36s %s\n" "list" "List saved profiles"
    printf "%-36s %s\n" "status" "Show detected Codex homes and active app profile"
    printf "%-36s %s\n" "create <profile>" "Create an empty profile directory"
    printf "%-36s %s\n" "save <profile> [--force] [--from PATH]" "Snapshot a Codex home into a profile"
    printf "%-36s %s\n" "import <profile> <path> [--force]" "Import an auth.json file or Codex home directory"
    printf "%-36s %s\n" "login <profile> [codex login args]" "Run codex login with CODEX_HOME set to profile"
    printf "%-36s %s\n" "cli <profile> [-- codex args]" "Run Codex CLI with CODEX_HOME set to profile"
    printf "%-36s %s\n" "app <profile> [--home PATH]" "Switch active Codex home for the desktop app"
    printf "%-36s %s\n" "backup [--home PATH]" "Backup the active Codex home"
    printf "%-36s %s\n" "help, -h, --help" "Show this help message"
    echo
    echo "${YELLOW}Examples:${NC}"
    echo "  llama codex-switch save personal"
    echo "  llama codex-switch login work --device-auth"
    echo "  llama codex-switch cli work"
    echo "  llama codex-switch cli work -- exec \"summarize this repo\""
    echo "  llama codex-switch app personal"
    echo
    echo "${YELLOW}Notes:${NC}"
    echo "  - CLI mode does not mutate ~/.codex; it runs codex with CODEX_HOME set."
    echo "  - App mode swaps the active Codex home. Restart the Codex app after switching."
    echo "  - auth.json contains access tokens. Profiles are stored under:"
    echo "    $PROFILES_DIR"
}

die() {
    echo "${RED}Error:${NC} $*" >&2
    exit 1
}

warn() {
    echo "${YELLOW}Warning:${NC} $*" >&2
}

ensure_base_dirs() {
    mkdir -p "$PROFILES_DIR" "$BACKUPS_DIR" || die "Could not create config directory: $CONFIG_DIR"
    chmod 700 "$CONFIG_DIR" "$PROFILES_DIR" "$BACKUPS_DIR" 2>/dev/null || true
}

validate_profile_name() {
    local profile="$1"
    case "$profile" in
        ""|.*|*/*|*\\*|*:*|*" "*)
            die "Invalid profile name '$profile'. Use letters, numbers, dotless names, underscores, or dashes."
            ;;
    esac

    if ! printf '%s' "$profile" | grep -Eq '^[A-Za-z0-9_-]+$'; then
        die "Invalid profile name '$profile'. Use only letters, numbers, underscores, and dashes."
    fi
}

profile_dir() {
    local profile="$1"
    validate_profile_name "$profile"
    printf '%s/%s\n' "$PROFILES_DIR" "$profile"
}

is_wsl() {
    grep -qiE '(microsoft|wsl)' /proc/version 2>/dev/null
}

default_cli_home() {
    printf '%s\n' "${CODEX_HOME:-$HOME/.codex}"
}

windows_userprofile_from_wsl() {
    local win_home

    if command -v powershell.exe >/dev/null 2>&1; then
        win_home=$(powershell.exe -NoProfile -Command '[Environment]::GetFolderPath("UserProfile")' 2>/dev/null | tr -d '\r' | tail -n 1)
        if [ -n "$win_home" ] && command -v wslpath >/dev/null 2>&1; then
            wslpath -u "$win_home" 2>/dev/null && return 0
        fi
    fi

    return 1
}

default_app_home() {
    local win_home

    if is_wsl; then
        win_home=$(windows_userprofile_from_wsl 2>/dev/null || true)
        if [ -n "$win_home" ]; then
            printf '%s/.codex\n' "$win_home"
            return 0
        fi
    fi

    printf '%s\n' "${CODEX_HOME:-$HOME/.codex}"
}

require_profile() {
    local profile="$1"
    local dir
    dir=$(profile_dir "$profile")
    [ -d "$dir" ] || die "Profile '$profile' does not exist. Create it with: llama codex-switch create $profile"
    printf '%s\n' "$dir"
}

timestamp() {
    date +%Y%m%d-%H%M%S
}

copy_dir_contents() {
    local source_dir="$1"
    local target_dir="$2"

    [ -d "$source_dir" ] || die "Source directory not found: $source_dir"

    mkdir -p "$target_dir" || die "Could not create target directory: $target_dir"
    rm -rf "$target_dir.tmp-copy" || die "Could not reset temporary directory: $target_dir.tmp-copy"
    mkdir -p "$target_dir.tmp-copy" || die "Could not create temporary directory: $target_dir.tmp-copy"
    cp -a "$source_dir/." "$target_dir.tmp-copy/" || die "Could not copy profile data from: $source_dir"
    rm -rf "$target_dir" || die "Could not replace target directory: $target_dir"
    mv "$target_dir.tmp-copy" "$target_dir" || die "Could not activate copied directory: $target_dir"
    chmod 700 "$target_dir" 2>/dev/null || true
    [ -f "$target_dir/auth.json" ] && chmod 600 "$target_dir/auth.json" 2>/dev/null || true
}

replace_dir_from_source() {
    local source_dir="$1"
    local target_dir="$2"
    local parent tmp_dir backup_dir base ts

    [ -d "$source_dir" ] || die "Source directory not found: $source_dir"

    parent=$(dirname "$target_dir")
    base=$(basename "$target_dir")
    ts=$(timestamp)
    tmp_dir="$parent/.${base}.codex-switch.$ts.$$"
    backup_dir="$BACKUPS_DIR/${base}.before-switch.$ts"

    mkdir -p "$parent" "$BACKUPS_DIR" || die "Could not prepare switch directories."
    rm -rf "$tmp_dir" || die "Could not reset temporary directory: $tmp_dir"
    mkdir -p "$tmp_dir" || die "Could not create temporary directory: $tmp_dir"
    cp -a "$source_dir/." "$tmp_dir/" || die "Could not copy profile data from: $source_dir"
    chmod 700 "$tmp_dir" 2>/dev/null || true
    [ -f "$tmp_dir/auth.json" ] && chmod 600 "$tmp_dir/auth.json" 2>/dev/null || true

    if [ -e "$target_dir" ]; then
        cp -a "$target_dir" "$backup_dir" || die "Could not backup current Codex home: $target_dir"
        rm -rf "$target_dir" || die "Could not remove current Codex home after backup: $target_dir"
        echo "Backed up previous Codex home to: $backup_dir"
    fi

    mv "$tmp_dir" "$target_dir" || die "Could not activate Codex home: $target_dir"
}

read_active_app_profile() {
    [ -f "$ACTIVE_APP_PROFILE_FILE" ] && sed -n '1p' "$ACTIVE_APP_PROFILE_FILE"
}

read_active_app_home() {
    [ -f "$ACTIVE_APP_HOME_FILE" ] && sed -n '1p' "$ACTIVE_APP_HOME_FILE"
}

write_active_app_state() {
    local profile="$1"
    local home_dir="$2"

    ensure_base_dirs
    printf '%s\n' "$profile" > "$ACTIVE_APP_PROFILE_FILE"
    printf '%s\n' "$home_dir" > "$ACTIVE_APP_HOME_FILE"
    chmod 600 "$ACTIVE_APP_PROFILE_FILE" "$ACTIVE_APP_HOME_FILE" 2>/dev/null || true
}

sync_current_app_back_to_profile() {
    local next_home="$1"
    local active_profile active_home active_dir

    active_profile=$(read_active_app_profile)
    active_home=$(read_active_app_home)

    [ -n "$active_profile" ] || return 0
    [ -n "$active_home" ] || return 0
    [ "$active_home" = "$next_home" ] || return 0
    [ -d "$active_home" ] || return 0

    active_dir=$(profile_dir "$active_profile")
    if [ -d "$active_dir" ]; then
        echo "Saving current app state back to profile: $active_profile"
        copy_dir_contents "$active_home" "$active_dir"
    fi
}

cmd_list() {
    ensure_base_dirs
    echo "${BLUE}Codex profiles${NC}"
    echo

    local found=0 profile auth_note
    for dir in "$PROFILES_DIR"/*; do
        [ -d "$dir" ] || continue
        found=1
        profile=$(basename "$dir")
        auth_note="${GRAY}no auth.json${NC}"
        [ -f "$dir/auth.json" ] && auth_note="${GREEN}auth.json${NC}"
        echo "  ${CYAN}$profile${NC}  $auth_note  ${GRAY}$dir${NC}"
    done

    [ "$found" -eq 1 ] || echo "  No profiles yet."
}

cmd_status() {
    ensure_base_dirs

    echo "${BLUE}Codex switch status${NC}"
    echo
    echo "  CLI default home:  $(default_cli_home)"
    echo "  App default home:  $(default_app_home)"
    echo "  Profiles:          $PROFILES_DIR"
    echo "  Backups:           $BACKUPS_DIR"
    echo

    local active_profile active_home
    active_profile=$(read_active_app_profile)
    active_home=$(read_active_app_home)
    if [ -n "$active_profile" ]; then
        echo "  Active app profile: ${CYAN}$active_profile${NC}"
        echo "  Active app home:    ${active_home:-unknown}"
    else
        echo "  Active app profile: ${GRAY}not tracked yet${NC}"
    fi
}

cmd_create() {
    local profile="$1"
    local dir

    [ -n "$profile" ] || die "Usage: llama codex-switch create <profile>"
    ensure_base_dirs
    dir=$(profile_dir "$profile")

    if [ -e "$dir" ]; then
        die "Profile '$profile' already exists."
    fi

    mkdir -p "$dir"
    chmod 700 "$dir" 2>/dev/null || true
    echo "${GREEN}Created profile:${NC} $profile"
    echo "Run login with: llama codex-switch login $profile"
}

cmd_save() {
    local profile="$1"
    shift || true

    [ -n "$profile" ] || die "Usage: llama codex-switch save <profile> [--force] [--from PATH]"

    local source_home force=0 dir
    source_home=$(default_cli_home)

    while [ $# -gt 0 ]; do
        case "$1" in
            --force)
                force=1
                shift
                ;;
            --from)
                source_home="$2"
                [ -n "$source_home" ] || die "--from requires a path"
                shift 2
                ;;
            *)
                die "Unknown option for save: $1"
                ;;
        esac
    done

    [ -d "$source_home" ] || die "Codex home not found: $source_home"

    ensure_base_dirs
    dir=$(profile_dir "$profile")
    if [ -e "$dir" ] && [ "$force" -ne 1 ]; then
        die "Profile '$profile' already exists. Use --force to overwrite it."
    fi

    copy_dir_contents "$source_home" "$dir"
    echo "${GREEN}Saved profile:${NC} $profile"
    echo "Source: $source_home"
}

cmd_import() {
    local profile="$1"
    local source_path="$2"
    shift 2 2>/dev/null || true

    [ -n "$profile" ] && [ -n "$source_path" ] || die "Usage: llama codex-switch import <profile> <auth.json-or-codex-home> [--force]"

    local force=0 dir
    while [ $# -gt 0 ]; do
        case "$1" in
            --force)
                force=1
                shift
                ;;
            *)
                die "Unknown option for import: $1"
                ;;
        esac
    done

    [ -e "$source_path" ] || die "Import source not found: $source_path"

    ensure_base_dirs
    dir=$(profile_dir "$profile")
    if [ -e "$dir" ] && [ "$force" -ne 1 ]; then
        die "Profile '$profile' already exists. Use --force to overwrite it."
    fi

    rm -rf "$dir" || die "Could not replace profile: $profile"
    mkdir -p "$dir" || die "Could not create profile directory: $dir"

    if [ -d "$source_path" ]; then
        cp -a "$source_path/." "$dir/" || die "Could not import Codex home: $source_path"
    else
        [ "$(basename "$source_path")" = "auth.json" ] || warn "Importing a single file as auth.json."
        cp "$source_path" "$dir/auth.json" || die "Could not import auth file: $source_path"
    fi

    chmod 700 "$dir" 2>/dev/null || true
    [ -f "$dir/auth.json" ] && chmod 600 "$dir/auth.json" 2>/dev/null || true
    echo "${GREEN}Imported profile:${NC} $profile"
}

cmd_login() {
    local profile="$1"
    shift || true

    [ -n "$profile" ] || die "Usage: llama codex-switch login <profile> [codex login args]"
    command -v codex >/dev/null 2>&1 || die "codex command not found in PATH."

    ensure_base_dirs
    local dir
    dir=$(profile_dir "$profile")
    mkdir -p "$dir"
    chmod 700 "$dir" 2>/dev/null || true

    echo "Running codex login with CODEX_HOME=$dir"
    CODEX_HOME="$dir" codex login "$@"
}

cmd_cli() {
    local profile="$1"
    shift || true

    [ -n "$profile" ] || die "Usage: llama codex-switch cli <profile> [-- codex args]"
    command -v codex >/dev/null 2>&1 || die "codex command not found in PATH."

    local dir
    dir=$(require_profile "$profile")

    if [ "${1:-}" = "--" ]; then
        shift
    fi

    echo "Using Codex CLI profile: $profile"
    echo "CODEX_HOME=$dir"
    CODEX_HOME="$dir" codex "$@"
}

cmd_app() {
    local profile="$1"
    shift || true

    [ -n "$profile" ] || die "Usage: llama codex-switch app <profile> [--home PATH]"

    local app_home
    app_home=$(default_app_home)

    while [ $# -gt 0 ]; do
        case "$1" in
            --home)
                app_home="$2"
                [ -n "$app_home" ] || die "--home requires a path"
                shift 2
                ;;
            *)
                die "Unknown option for app: $1"
                ;;
        esac
    done

    local dir
    dir=$(require_profile "$profile")

    ensure_base_dirs
    sync_current_app_back_to_profile "$app_home"
    replace_dir_from_source "$dir" "$app_home"
    write_active_app_state "$profile" "$app_home"

    echo "${GREEN}Switched Codex app profile:${NC} $profile"
    echo "Active Codex home: $app_home"
    echo "${YELLOW}Restart the Codex app for the switch to take effect.${NC}"
}

cmd_backup() {
    local app_home
    app_home=$(default_app_home)

    while [ $# -gt 0 ]; do
        case "$1" in
            --home)
                app_home="$2"
                [ -n "$app_home" ] || die "--home requires a path"
                shift 2
                ;;
            *)
                die "Unknown option for backup: $1"
                ;;
        esac
    done

    [ -d "$app_home" ] || die "Codex home not found: $app_home"

    ensure_base_dirs
    local backup_dir="$BACKUPS_DIR/manual.$(timestamp)"
    mkdir -p "$backup_dir" || die "Could not create backup directory: $backup_dir"
    cp -a "$app_home/." "$backup_dir/" || die "Could not backup Codex home: $app_home"
    chmod 700 "$backup_dir" 2>/dev/null || true
    [ -f "$backup_dir/auth.json" ] && chmod 600 "$backup_dir/auth.json" 2>/dev/null || true

    echo "${GREEN}Backup created:${NC} $backup_dir"
}

case "${1:-}" in
    list)
        cmd_list
        ;;
    status)
        cmd_status
        ;;
    create)
        shift
        cmd_create "$@"
        ;;
    save)
        shift
        cmd_save "$@"
        ;;
    import)
        shift
        cmd_import "$@"
        ;;
    login)
        shift
        cmd_login "$@"
        ;;
    cli)
        shift
        cmd_cli "$@"
        ;;
    app)
        shift
        cmd_app "$@"
        ;;
    backup)
        shift
        cmd_backup "$@"
        ;;
    help|-h|--help|"")
        show_help
        ;;
    *)
        die "Unknown command '$1'. Run 'llama codex-switch help'."
        ;;
esac
