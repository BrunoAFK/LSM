VERSION="2.6.7"

#------------------------------------------------------------------------------
# Colors
#------------------------------------------------------------------------------
RED=$'\033[1;31m'
GREEN=$'\033[1;32m'
YELLOW=$'\033[1;33m'
BLUE=$'\033[1;34m'
CYAN=$'\033[1;36m'
NC=$'\033[0m'
SUDO_READY=0
USE_SUDO=0
GITHUB_USER="BrunoAFK"
GITHUB_REPO="LSM"
GITHUB_BRANCH="main"
DEV_DIR="/opt/llama"
DEFAULT_INSTALL_DIR="/usr/local/lib/llama"
DEFAULT_BIN_DIR="/usr/local/bin"
CONFIG_DIR="$HOME/.config/llama_env"
INSTALL_CONFIG_FILE="$CONFIG_DIR/install.conf"
INSTALL_DIR="$DEFAULT_INSTALL_DIR"
BIN_DIR="$DEFAULT_BIN_DIR"
SCRIPTS_DIR_PROD=""
SCRIPTS_DIR_DEV="$DEV_DIR/scripts"
GITHUB_RAW_BASE="https://raw.githubusercontent.com/$GITHUB_USER/$GITHUB_REPO/$GITHUB_BRANCH"
GITHUB_API_BASE="https://api.github.com/repos/$GITHUB_USER/$GITHUB_REPO"
TEMP_DIR=""

# Determines if the script is running from the development directory
# Returns: true if running from DEV_DIR, false otherwise
is_dev_mode() {
    local script_dir
    script_dir="$(cd -- "$(dirname -- "$0")" && pwd -P)"
    [[ "$script_dir" == "$DEV_DIR" ]]
}

load_install_config() {
    local line key value

    [ -f "$INSTALL_CONFIG_FILE" ] || return 0

    while IFS= read -r line || [ -n "$line" ]; do
        case "$line" in
            ""|\#*)
                continue
                ;;
            *=*)
                key="${line%%=*}"
                value="${line#*=}"
                case "$key" in
                    INSTALL_DIR)
                        [ -n "$value" ] && INSTALL_DIR="$value"
                        ;;
                    BIN_DIR)
                        [ -n "$value" ] && BIN_DIR="$value"
                        ;;
                esac
                ;;
        esac
    done < "$INSTALL_CONFIG_FILE"
}

# Creates a temporary directory and registers cleanup handler
# Sets global TEMP_DIR variable and ensures directory removal on script exit
setup_temp_dir() {
    TEMP_DIR=$(mktemp -d)
    trap 'rm -rf "$TEMP_DIR"' EXIT
}

# Returns appropriate installation and scripts directories based on current mode
# Output: Space-separated string containing install_dir and scripts_dir paths
get_directories() {
    if is_dev_mode; then
        echo "$DEV_DIR" "$SCRIPTS_DIR_DEV"
    else
        echo "$INSTALL_DIR" "$INSTALL_DIR/scripts"
    fi
}

# Determines the appropriate binary installation path for the current OS
# Currently supports macOS and Linux systems
# Returns: Path string for binary installation
get_bin_path() {
    echo "$BIN_DIR"
}

persist_install_config() {
    mkdir -p "$CONFIG_DIR"
    if [ "$INSTALL_DIR" = "$DEFAULT_INSTALL_DIR" ] && [ "$BIN_DIR" = "$DEFAULT_BIN_DIR" ]; then
        rm -f "$INSTALL_CONFIG_FILE"
        return 0
    fi

    {
        printf 'INSTALL_DIR=%s\n' "$INSTALL_DIR"
        printf 'BIN_DIR=%s\n' "$BIN_DIR"
    } > "$INSTALL_CONFIG_FILE"
    chmod 600 "$INSTALL_CONFIG_FILE" 2>/dev/null || true
}

is_path_writable() {
    local path="$1"
    local parent

    if [ -e "$path" ]; then
        [ -w "$path" ]
        return $?
    fi

    parent=$(dirname "$path")
    while [ ! -d "$parent" ] && [ "$parent" != "/" ]; do
        parent=$(dirname "$parent")
    done

    [ -w "$parent" ]
}

configure_privilege_mode() {
    local install_dir scripts_dir bin_path

    read -r install_dir scripts_dir <<<"$(get_directories)"
    bin_path=$(get_bin_path)
    USE_SUDO=0

    [ "$(id -u)" -eq 0 ] && return 0
    is_dev_mode && return 0

    if ! is_path_writable "$install_dir" || ! is_path_writable "$scripts_dir" || ! is_path_writable "$bin_path"; then
        USE_SUDO=1
    fi
}

run_install_command() {
    if [ "$USE_SUDO" -eq 1 ] && [ "$(id -u)" -ne 0 ]; then
        sudo "$@"
    else
        "$@"
    fi
}

ensure_path_note() {
    local bin_path
    bin_path=$(get_bin_path)
    case ":$PATH:" in
        *":$bin_path:"*)
            ;;
        *)
            echo
            echo "${YELLOW}Note:${NC} $bin_path is not currently in PATH."
            echo "Add it to your shell profile if you want to run 'llama' directly."
            ;;
    esac
}

prompt_for_user_install_location() {
    local default_install_dir="$HOME/.local/lib/llama"
    local default_bin_dir="$HOME/.local/bin"
    local input_install_dir input_bin_dir

    if ! [ -r /dev/tty ] || ! [ -w /dev/tty ]; then
        return 1
    fi

    echo
    echo "${YELLOW}You can install llama without sudo in your home directory instead.${NC}"
    echo "The command symlink will be placed in the bin directory you choose."
    echo "That directory must be in PATH."

    printf "Install directory [%s]: " "$default_install_dir" > /dev/tty
    read -r input_install_dir < /dev/tty || return 1
    printf "Bin directory for the 'llama' command [%s]: " "$default_bin_dir" > /dev/tty
    read -r input_bin_dir < /dev/tty || return 1

    INSTALL_DIR="${input_install_dir:-$default_install_dir}"
    BIN_DIR="${input_bin_dir:-$default_bin_dir}"
    USE_SUDO=0
    persist_install_config

    echo
    echo "${GREEN}Using user install paths:${NC}"
    echo "  Install: $INSTALL_DIR"
    echo "  Bin:     $BIN_DIR"
    ensure_path_note
    return 0
}

prompt_for_sudo() {
    local reason="$1"
    shift
    local step

    if [ "$(id -u)" -eq 0 ] || [ "$SUDO_READY" -eq 1 ] || [ "$USE_SUDO" -eq 0 ]; then
        return 0
    fi

    echo
    echo "${YELLOW}This action needs administrator access.${NC}"
    echo "$reason"
    if [ $# -gt 0 ]; then
        echo "It will run commands like:"
        for step in "$@"; do
            echo "  - $step"
        done
    fi

    if [ -r /dev/tty ] && [ -w /dev/tty ]; then
        printf "Continue and allow sudo? [y/N] " > /dev/tty
        read -r reply < /dev/tty || return 1
        case "$reply" in
            y|Y|yes|YES)
                ;;
            *)
                return 1
                ;;
        esac
    else
        echo "Requesting sudo access now..."
    fi

    if ! sudo -v; then
        echo "${RED}Error:${NC} Could not obtain sudo access."
        return 1
    fi

    SUDO_READY=1
    return 0
}

# Display help information with environment indication and script descriptions
show_help() {
    local env_type
    env_type=$(is_dev_mode && echo "DEVELOPMENT" || echo "PRODUCTION")
    echo "${BLUE}Llama Script Manager v$VERSION${NC}"
    echo "Environment: ${YELLOW}$env_type${NC}"
    echo
    echo "${GREEN}Usage:${NC}"
    echo "  llama <command> [args]"
    echo "  llama <script> [args]"
    echo
    echo "${YELLOW}Commands:${NC}"
    printf "%-25s %-45s\n" "help, -h" "Show this help message"
    printf "%-25s %-45s\n" "update, -u" "Update llama and installed scripts"
    printf "%-25s %-45s\n" "status, -s" "Show environment status"
    printf "%-25s %-45s\n" "install, -i" "Install llama from scratch"
    printf "%-25s %-45s\n" "remove, -r" "Uninstall llama completely"
    echo
    echo "${YELLOW}Script Management:${NC}"
    printf "%-25s %-45s\n" "scripts list" "Show all available scripts"
    printf "%-25s %-45s\n" "scripts add <name>" "Install a script"
    printf "%-25s %-45s\n" "scripts remove <name>" "Remove a script"
    echo
    echo "${YELLOW}Examples:${NC}"
    echo "  llama update"
    echo "  llama scripts list"
    echo "  llama scripts add docker-scan"
    echo "  llama docker-update run"
    echo "  llama docker-scan help"
    echo
    echo "${YELLOW}Installed Scripts:${NC}"
    read -r install_dir scripts_dir <<<"$(get_directories)"
    if [ -d "$scripts_dir" ]; then
        local found=false
        for script in "$scripts_dir"/*; do
            if [ -x "$script" ]; then
                found=true
                script_name=$(basename "$script")
                description=$(head -n 20 "$script" | grep -i "^#.*description:" | head -n 1 | sed 's/^#[ ]*[Dd]escription:[ ]*//')
                printf "  ${CYAN}%-20s${NC} %s\n" "$script_name" "${description:-No description}"
            fi
        done
        $found || echo "  No scripts installed. Run 'llama scripts list' to see available."
    else
        echo "  No scripts installed. Run 'llama scripts list' to see available."
    fi
    echo
}

# Download a file from GitHub and check the response
download_file() {
    local path="$1"
    local output="$2"
    local response

    response=$(curl -fsSL -w "%{http_code}" "$GITHUB_RAW_BASE/$path" -o "$output")

    if [ "$response" != "200" ]; then
        rm -f "$output"
        return 1
    fi
    return 0
}

# Create a symbolic link for the main script
create_symlink() {
    local bin_path
    local install_dir
    bin_path=$(get_bin_path)
    read -r install_dir _ <<<"$(get_directories)"
    if ! is_dev_mode; then
        run_install_command mkdir -p "$bin_path"
        run_install_command ln -sf "$install_dir/llama" "$bin_path/llama"
        echo "Created symbolic link in $bin_path"
    fi
}

# Install from local development directory
install_from_dev() {
    echo "Installing from development directory..."
    read -r install_dir scripts_dir <<<"$(get_directories)"

    run_install_command mkdir -p "$install_dir"
    run_install_command mkdir -p "$scripts_dir"

    # Copy main script
    local script_path
    script_path="$(cd -- "$(dirname -- "$0")" && pwd -P)/$(basename -- "$0")"
    if [ "$script_path" != "$install_dir/llama" ]; then
        run_install_command cp "$0" "$install_dir/llama"
        run_install_command chmod +x "$install_dir/llama"
    fi

    # Copy scripts
    if [ -d "$DEV_DIR/scripts" ]; then
        run_install_command cp -r "$DEV_DIR/scripts/"* "$scripts_dir/"
        while IFS= read -r script_file; do
            run_install_command chmod +x "$script_file"
        done < <(find "$scripts_dir" -type f)
    fi
}

# Install from GitHub (production only)
install_from_github() {
    echo "Installing from GitHub..."
    read -r install_dir scripts_dir <<<"$(get_directories)"

    run_install_command mkdir -p "$install_dir"
    run_install_command mkdir -p "$scripts_dir"

    # Clone the repository
    if ! git clone --depth 1 --branch "$GITHUB_BRANCH" --single-branch \
        "https://github.com/$GITHUB_USER/$GITHUB_REPO.git" "$TEMP_DIR/repo"; then
        echo "Failed to clone repository"
        return 1
    fi

    if [ -d "$TEMP_DIR/repo" ]; then
        if [ ! -f "$TEMP_DIR/repo/llama" ]; then
            echo "Repository missing expected files"
            return 1
        fi
        # Update main script
        run_install_command cp "$TEMP_DIR/repo/llama" "$install_dir/llama"
        run_install_command chmod +x "$install_dir/llama"

        # Only update existing scripts
        if [ -d "$TEMP_DIR/repo/scripts" ] && [ -d "$scripts_dir" ]; then
            # Loop through existing scripts and update only those
            for existing_script in "$scripts_dir"/*; do
                if [ -f "$existing_script" ]; then
                    script_name=$(basename "$existing_script")
                    if [ -f "$TEMP_DIR/repo/scripts/$script_name" ]; then
                        echo "Updating script: $script_name"
                        run_install_command cp "$TEMP_DIR/repo/scripts/$script_name" "$scripts_dir/$script_name"
                        run_install_command chmod +x "$scripts_dir/$script_name"
                    fi
                fi
            done
        fi
    else
        echo "Failed to clone repository"
        return 1
    fi
}

# Main install function
install_script() {
    local install_dir scripts_dir bin_path env_type
    local -a sudo_steps

    echo "Installing llama..."
    setup_temp_dir

    configure_privilege_mode
    read -r install_dir scripts_dir <<<"$(get_directories)"
    bin_path=$(get_bin_path)
    env_type=$(is_dev_mode && echo "development" || echo "production")
    sudo_steps=(
        "mkdir -p $install_dir"
        "mkdir -p $scripts_dir"
        "copy llama and installed scripts into $install_dir"
        "update executable permissions on installed files"
    )
    if ! is_dev_mode; then
        sudo_steps+=("mkdir -p $bin_path")
        sudo_steps+=("ln -sf $install_dir/llama $bin_path/llama")
    fi

    if ! prompt_for_sudo \
        "Installing in $env_type mode writes LSM files outside your home directory." \
        "${sudo_steps[@]}"; then
        if ! is_dev_mode && prompt_for_user_install_location; then
            read -r install_dir scripts_dir <<<"$(get_directories)"
            bin_path=$(get_bin_path)
        else
            echo "Installation cancelled before privileged changes."
            return 0
        fi
    fi

    if is_dev_mode; then
        install_from_dev
    else
        install_from_github
    fi

    create_symlink
    persist_install_config
    ensure_path_note
    echo "Installation completed in $(is_dev_mode && echo "DEVELOPMENT" || echo "PRODUCTION") mode"
}

# Remove the script and its components
remove_script() {
    read -r install_dir scripts_dir <<<"$(get_directories)"
    local bin_path=$(get_bin_path)
    configure_privilege_mode

    if ! prompt_for_sudo \
        "Removing LSM deletes files from system installation paths." \
        "rm $bin_path/llama" \
        "rm -rf $scripts_dir" \
        "rm -rf $install_dir"; then
        echo "Removal cancelled before privileged changes."
        return 0
    fi

    if ! is_dev_mode && [ -L "$bin_path/llama" ]; then
        run_install_command rm "$bin_path/llama"
        echo "Removed symbolic link from $bin_path"
    fi

    if [ -d "$scripts_dir" ]; then
        run_install_command rm -rf "$scripts_dir"
        echo "Removed scripts directory $scripts_dir"
    fi

    if [ -d "$install_dir" ]; then
        run_install_command rm -rf "$install_dir"
        echo "Removed installation directory $install_dir"
    fi

    [ -f "$INSTALL_CONFIG_FILE" ] && rm -f "$INSTALL_CONFIG_FILE"

    echo "Llama removed successfully from $(is_dev_mode && echo "DEVELOPMENT" || echo "PRODUCTION") environment"
}

# Show current status
show_status() {
    local env_type=$(is_dev_mode && echo "DEVELOPMENT" || echo "PRODUCTION")
    read -r install_dir scripts_dir <<<"$(get_directories)"

    echo "${BLUE}Llama Script Manager Status${NC}"
    echo "Environment: ${YELLOW}$env_type${NC}"
    echo "Version: ${GREEN}$VERSION${NC}"
    echo "Installation Directory: ${CYAN}$install_dir${NC}"
    echo "Scripts Directory: ${CYAN}$scripts_dir${NC}"

    if [ -d "$scripts_dir" ]; then
        echo
        echo "Installed Scripts:"
        for script in "$scripts_dir"/*; do
            if [ -x "$script" ]; then
                echo "  - $(basename "$script")"
            fi
        done
    fi
}

# SHA256 helper — works on both macOS and Linux
sha256_file() {
    local file="$1"
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "$file" | awk '{print $1}'
    elif command -v shasum >/dev/null 2>&1; then
        shasum -a 256 "$file" | awk '{print $1}'
    else
        echo ""
    fi
}

get_script_version() {
    local script_path="$1"
    head -n 20 "$script_path" | grep -i "^#.*version:" | head -n 1 | sed 's/^#[ ]*[Vv]ersion:[ ]*//'
}

compare_versions() {
    local version1=$1
    local version2=$2
    local v1=(${version1//./ })
    local v2=(${version2//./ })

    for i in {0..2}; do
        if [ "${v1[$i]:-0}" -gt "${v2[$i]:-0}" ]; then
            echo "1"; return
        elif [ "${v1[$i]:-0}" -lt "${v2[$i]:-0}" ]; then
            echo "-1"; return
        fi
    done
    echo "0"
}

# Fetch latest release info from GitHub Releases API
# Sets: RELEASE_TAG, RELEASE_CHECKSUM_URL
fetch_release_info() {
    local api_response
    api_response=$(curl -fsSL "$GITHUB_API_BASE/releases/latest" 2>/dev/null) || {
        echo "Error: Could not reach GitHub API"
        return 1
    }

    RELEASE_TAG=$(echo "$api_response" | grep '"tag_name"' | head -1 | sed -E 's/.*"tag_name"[[:space:]]*:[[:space:]]*"v?([^"]+)".*/\1/')

    if [ -z "$RELEASE_TAG" ]; then
        RELEASE_TAG=""
        return 1
    fi

    RELEASE_CHECKSUM_URL=$(echo "$api_response" | grep '"browser_download_url"' | grep 'checksums.txt' | head -1 | sed -E 's/.*"browser_download_url"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/')
}

# Verify downloaded files against checksums.txt
verify_checksums() {
    local checksum_file="$1"
    local target_dir="$2"

    if [ ! -f "$checksum_file" ]; then
        echo "${YELLOW}Warning:${NC} No checksums file — skipping verification"
        return 0
    fi

    local failed=0
    while IFS= read -r line; do
        [ -z "$line" ] && continue
        local expected_hash file_name
        expected_hash=$(echo "$line" | awk '{print $1}')
        file_name=$(echo "$line" | awk '{print $2}')
        # Remove leading ./ or */ from filename
        file_name=$(basename "$file_name")

        local target_file="$target_dir/$file_name"
        if [ ! -f "$target_file" ]; then
            # Check in scripts subdir
            target_file="$target_dir/scripts/$file_name"
            [ ! -f "$target_file" ] && continue
        fi

        local actual_hash
        actual_hash=$(sha256_file "$target_file")

        if [ "$expected_hash" != "$actual_hash" ]; then
            echo "${RED}Checksum FAILED:${NC} $file_name"
            echo "  Expected: $expected_hash"
            echo "  Got:      $actual_hash"
            failed=1
        else
            echo "  ${GREEN}✓${NC} $file_name"
        fi
    done < "$checksum_file"

    return $failed
}

# Update using GitHub Releases API with checksum verification
update_from_release() {
    setup_temp_dir

    echo "Checking GitHub releases..."
    if ! fetch_release_info; then
        echo "No releases found, falling back to branch update..."
        update_from_branch
        return $?
    fi

    local remote_version="$RELEASE_TAG"
    echo "Current version: $VERSION"
    echo "Latest release:  $remote_version"

    local version_compare
    version_compare=$(compare_versions "$VERSION" "$remote_version")

    if [ "$version_compare" != "-1" ]; then
        echo "Already up to date."
        return 0
    fi

    echo "${GREEN}Update available: $VERSION → $remote_version${NC}"

    # Clone the release tag
    echo "Downloading release $remote_version..."
    if ! git clone --depth 1 --branch "v$remote_version" --single-branch \
        "https://github.com/$GITHUB_USER/$GITHUB_REPO.git" "$TEMP_DIR/repo" 2>/dev/null; then
        # Try without v prefix
        if ! git clone --depth 1 --branch "$remote_version" --single-branch \
            "https://github.com/$GITHUB_USER/$GITHUB_REPO.git" "$TEMP_DIR/repo" 2>/dev/null; then
            echo "Failed to download release"
            return 1
        fi
    fi

    if [ ! -f "$TEMP_DIR/repo/llama" ]; then
        echo "Release is missing expected files"
        return 1
    fi

    # Download and verify checksums if available
    if [ -n "$RELEASE_CHECKSUM_URL" ]; then
        echo "Verifying checksums..."
        if curl -fsSL -o "$TEMP_DIR/checksums.txt" "$RELEASE_CHECKSUM_URL"; then
            if ! verify_checksums "$TEMP_DIR/checksums.txt" "$TEMP_DIR/repo"; then
                echo "${RED}Checksum verification failed — aborting update${NC}"
                return 1
            fi
            echo "${GREEN}Checksums verified${NC}"
        else
            echo "${YELLOW}Warning:${NC} Could not download checksums — proceeding without verification"
        fi
    else
        echo "${YELLOW}Note:${NC} No checksums in this release — proceeding without verification"
    fi

    # Install verified files
    read -r install_dir scripts_dir <<<"$(get_directories)"
    local bin_path
    bin_path=$(get_bin_path)
    configure_privilege_mode

    if ! prompt_for_sudo \
        "Applying the update writes verified release files into protected install directories." \
        "mkdir -p $install_dir $scripts_dir" \
        "mkdir -p $bin_path" \
        "install $TEMP_DIR/repo/llama into $install_dir" \
        "install updated scripts into $scripts_dir" \
        "ln -sf $install_dir/llama $bin_path/llama"; then
        echo "Update cancelled before privileged changes."
        return 0
    fi

    run_install_command mkdir -p "$install_dir" "$scripts_dir"

    # Update main script
    run_install_command install -m 755 "$TEMP_DIR/repo/llama" "$install_dir/llama"
    echo "Updated llama → $remote_version"

    # Update existing scripts
    if [ -d "$TEMP_DIR/repo/scripts" ] && [ -d "$scripts_dir" ]; then
        for existing_script in "$scripts_dir"/*; do
            [ -f "$existing_script" ] || continue
            local script_name
            script_name=$(basename "$existing_script")
            if [ -f "$TEMP_DIR/repo/scripts/$script_name" ]; then
                run_install_command install -m 755 "$TEMP_DIR/repo/scripts/$script_name" "$scripts_dir/$script_name"
                echo "Updated script: $script_name"
            fi
        done
    fi

    create_symlink
    persist_install_config
    echo "${GREEN}Update completed successfully.${NC}"
    echo "Restart llama to use the new version."
    exit 0
}

# Fallback: update from branch (for repos without releases)
update_from_branch() {
    setup_temp_dir

    local remote_version
    remote_version=$(curl -fsSL "$GITHUB_RAW_BASE/llama" 2>/dev/null | grep "^VERSION=" | cut -d'"' -f2)

    if [ -z "$remote_version" ]; then
        echo "Error: Could not fetch remote version"
        return 1
    fi

    echo "Current version: $VERSION"
    echo "Remote version:  $remote_version"

    local version_compare
    version_compare=$(compare_versions "$VERSION" "$remote_version")

    if [ "$version_compare" != "-1" ]; then
        echo "Already up to date."
        return 0
    fi

    echo "${GREEN}Update available: $VERSION → $remote_version${NC}"

    if ! git clone --depth 1 --branch "$GITHUB_BRANCH" --single-branch \
        "https://github.com/$GITHUB_USER/$GITHUB_REPO.git" "$TEMP_DIR/repo" 2>/dev/null; then
        echo "Failed to clone repository"
        return 1
    fi

    if [ ! -f "$TEMP_DIR/repo/llama" ]; then
        echo "Repository missing expected files"
        return 1
    fi

    read -r install_dir scripts_dir <<<"$(get_directories)"
    local bin_path
    bin_path=$(get_bin_path)
    configure_privilege_mode

    if ! prompt_for_sudo \
        "Applying the update writes downloaded files into protected install directories." \
        "mkdir -p $install_dir $scripts_dir" \
        "mkdir -p $bin_path" \
        "install $TEMP_DIR/repo/llama into $install_dir" \
        "install updated scripts into $scripts_dir" \
        "ln -sf $install_dir/llama $bin_path/llama"; then
        echo "Update cancelled before privileged changes."
        return 0
    fi

    run_install_command mkdir -p "$install_dir" "$scripts_dir"

    run_install_command install -m 755 "$TEMP_DIR/repo/llama" "$install_dir/llama"
    echo "Updated llama → $remote_version"

    if [ -d "$TEMP_DIR/repo/scripts" ] && [ -d "$scripts_dir" ]; then
        for existing_script in "$scripts_dir"/*; do
            [ -f "$existing_script" ] || continue
            local script_name
            script_name=$(basename "$existing_script")
            if [ -f "$TEMP_DIR/repo/scripts/$script_name" ]; then
                run_install_command install -m 755 "$TEMP_DIR/repo/scripts/$script_name" "$scripts_dir/$script_name"
                echo "Updated script: $script_name"
            fi
        done
    fi

    create_symlink
    persist_install_config
    echo "${GREEN}Update completed successfully.${NC}"
    echo "Restart llama to use the new version."
    exit 0
}

# Show new scripts available in repo that aren't installed locally
show_new_scripts() {
    local repo_scripts_dir="$1"
    read -r _ scripts_dir <<<"$(get_directories)"

    [ ! -d "$repo_scripts_dir" ] && return

    local new_scripts=()
    for remote_script in "$repo_scripts_dir"/*; do
        [ -f "$remote_script" ] || continue
        local name
        name=$(basename "$remote_script")
        if [ ! -f "$scripts_dir/$name" ]; then
            local desc
            desc=$(head -n 20 "$remote_script" | grep -i "^#.*description:" | head -n 1 | sed 's/^#[ ]*[Dd]escription:[ ]*//')
            new_scripts+=("$name|${desc:-No description}")
        fi
    done

    if [ ${#new_scripts[@]} -gt 0 ]; then
        echo
        echo "${YELLOW}New scripts available:${NC}"
        for entry in "${new_scripts[@]}"; do
            local name="${entry%%|*}"
            local desc="${entry#*|}"
            echo "  ${CYAN}$name${NC} — $desc"
        done
        echo
        echo "Install with: llama scripts add <name>"
    fi
}

# List all available scripts (installed and not installed)
list_scripts() {
    setup_temp_dir

    echo "${BLUE}Available Scripts${NC}"
    echo

    # Clone repo to see all scripts
    if ! git clone --depth 1 --branch "$GITHUB_BRANCH" --single-branch \
        "https://github.com/$GITHUB_USER/$GITHUB_REPO.git" "$TEMP_DIR/repo" 2>/dev/null; then
        echo "Error: Could not fetch script list from GitHub"
        return 1
    fi

    read -r _ scripts_dir <<<"$(get_directories)"

    if [ ! -d "$TEMP_DIR/repo/scripts" ]; then
        echo "No scripts found in repository."
        return 0
    fi

    for remote_script in "$TEMP_DIR/repo/scripts"/*; do
        [ -f "$remote_script" ] || continue
        local name
        name=$(basename "$remote_script")
        local desc
        desc=$(head -n 20 "$remote_script" | grep -i "^#.*description:" | head -n 1 | sed 's/^#[ ]*[Dd]escription:[ ]*//')
        desc="${desc:-No description}"

        if [ -f "$scripts_dir/$name" ]; then
            echo "  ${GREEN}●${NC} ${CYAN}$name${NC} — $desc"
        else
            echo "  ${RED}○${NC} ${CYAN}$name${NC} — $desc"
        fi
    done

    echo
    echo "  ${GREEN}●${NC} = installed    ${RED}○${NC} = not installed"
    echo
    echo "Install with: llama scripts add <name>"
    echo "Remove with:  llama scripts remove <name>"
}

# Install a specific script by name
install_single_script() {
    local script_name="$1"
    configure_privilege_mode

    if [ -z "$script_name" ]; then
        echo "Usage: llama scripts add <script-name>"
        echo "Run 'llama scripts list' to see available scripts."
        return 1
    fi

    read -r install_dir scripts_dir <<<"$(get_directories)"

    if [ -f "$scripts_dir/$script_name" ]; then
        echo "Script '$script_name' is already installed. Use 'llama update' to update it."
        return 0
    fi

    setup_temp_dir

    echo "Fetching script '$script_name'..."
    if ! git clone --depth 1 --branch "$GITHUB_BRANCH" --single-branch \
        "https://github.com/$GITHUB_USER/$GITHUB_REPO.git" "$TEMP_DIR/repo" 2>/dev/null; then
        echo "Error: Could not fetch from GitHub"
        return 1
    fi

    if [ ! -f "$TEMP_DIR/repo/scripts/$script_name" ]; then
        echo "${RED}Error:${NC} Script '$script_name' not found in repository."
        echo "Run 'llama scripts list' to see available scripts."
        return 1
    fi

    if ! prompt_for_sudo \
        "Installing a script writes files into the shared LSM scripts directory." \
        "mkdir -p $scripts_dir" \
        "install $script_name into $scripts_dir"; then
        echo "Script installation cancelled before privileged changes."
        return 0
    fi

    run_install_command mkdir -p "$scripts_dir"
    run_install_command install -m 755 "$TEMP_DIR/repo/scripts/$script_name" "$scripts_dir/$script_name"
    echo "${GREEN}Installed:${NC} $script_name"
}

# Remove a specific script by name
remove_single_script() {
    local script_name="$1"
    configure_privilege_mode

    if [ -z "$script_name" ]; then
        echo "Usage: llama scripts remove <script-name>"
        echo "Run 'llama scripts list' to see available scripts."
        return 1
    fi

    read -r _ scripts_dir <<<"$(get_directories)"

    if [ ! -f "$scripts_dir/$script_name" ]; then
        echo "${RED}Error:${NC} Script '$script_name' is not installed."
        return 1
    fi

    if ! prompt_for_sudo \
        "Removing a script deletes files from the shared LSM scripts directory." \
        "rm $scripts_dir/$script_name"; then
        echo "Script removal cancelled before privileged changes."
        return 0
    fi

    run_install_command rm "$scripts_dir/$script_name"
    echo "${GREEN}Removed:${NC} $script_name"
}

update_script() {
    if is_dev_mode; then
        echo "Development mode: Installing from local files..."
        install_from_dev
    else
        echo "Production mode: Checking for updates..."
        update_from_release
    fi
}

load_install_config

# Main command router
# Processes command-line arguments and executes appropriate functions
# If no known command is provided, attempts to execute it as a script
case "$1" in
"help" | "-h")
    show_help
    ;;
"install" | "-i")
    install_script
    ;;
"remove" | "-r")
    remove_script
    ;;
"update" | "-u")
    update_script
    ;;
"scripts")
    case "$2" in
        "list" | "")
            list_scripts
            ;;
        "add")
            install_single_script "$3"
            ;;
        "remove")
            remove_single_script "$3"
            ;;
        "help" | "-h")
            echo "${BLUE}Script Management${NC}"
            echo
            echo "${YELLOW}Usage:${NC}"
            echo "  llama scripts <command> [name]"
            echo
            echo "${YELLOW}Commands:${NC}"
            printf "  %-20s %s\n" "list" "Show all available scripts (installed and not)"
            printf "  %-20s %s\n" "add <name>" "Install a script from the repository"
            printf "  %-20s %s\n" "remove <name>" "Remove an installed script"
            printf "  %-20s %s\n" "help" "Show this help"
            echo
            echo "${YELLOW}Examples:${NC}"
            echo "  llama scripts list"
            echo "  llama scripts add docker-scan"
            echo "  llama scripts remove test"
            ;;
        *)
            echo "${RED}Error:${NC} Unknown scripts command '$2'."
            echo "Run 'llama scripts help' for usage."
            exit 1
            ;;
    esac
    ;;
"status" | "-s")
    show_status
    ;;
"")
    show_help
    ;;
*)
    if [ -z "$1" ]; then
        echo "Error: No script specified"
        show_help
        exit 1
    fi

    read -r install_dir scripts_dir <<<"$(get_directories)"
    script_path="$scripts_dir/$1"
    if [[ -x "$script_path" ]]; then
        shift
        exec "$script_path" "$@"
    else
        echo "${RED}Error:${NC} Script '$1' not found."
        echo "Run 'llama scripts list' to see available scripts."
        exit 1
    fi
    ;;
esac
